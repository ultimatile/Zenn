{
  "rules": {
    "preset-ja-technical-writing": {
      "no-exclamation-question-mark": false,
      "sentence-length": false,
      "max-ten": false,
      "ja-no-weak-phrase": false,
      "arabic-kanji-numbers": false,
      "no-doubled-joshi": {
        "allow": ["も", "ても"]
      },
      "ja-no-mixed-period": {
        "allowPeriodMarks": ["?", "!"]
      }
    },
    "prh": {
      "rulePaths": ["./prh.yml"]
    }
  }
}
