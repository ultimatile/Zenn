{
  "rules": {
    "preset-ja-technical-writing": {
      "no-exclamation-question-mark": false,
      "sentence-length": false,
      "max-ten": false,
      "ja-no-weak-phrase": false,
      "arabic-kanji-numbers": false,
      "no-mix-dearu-desumasu": false,
      "no-doubled-joshi": {
        "allow": ["сѓѓ", "сЂдсѓѓ"]
      },
      "ja-no-mixed-period": {
        "allowPeriodMarks": ["?", "!"]
      }
    },
    "prh": {
      "rulePaths": ["./prh.yml"]
    },
    "ja-joyo-or-jinmeiyo-kanji": true
  },
  "filters": {
    "comments": true,
    "allowlist": {
      "allow": [
        "у╣І",
        "жќЙ",
        "тЈЕ",
        "С╣ќ",
        "тєф",
        "Тб▒",
        "тЅЦ",
        "Тј┤",
        "уйа",
        "уЅб",
        "жеЎ",
        "Уѕљ",
        "тхї",
        "тЎЏ",
        "тўў"
      ]
    }
  }
}
